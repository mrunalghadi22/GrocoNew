<div class="table-container">
  <div class="table-top">
    <div class="search-box">
      <input
        type="text"
        class="search-input"
        id="searchInput"
        placeholder="Search for products..."
        onkeyup="searchTable()"
      />
      <div class="search-icon">
        <i class="fa-solid fa-magnifying-glass"></i>
      </div>
    </div>
  </div>
  <table>
    <thead>
      <tr>
        <th>Product</th>
        <th>Name</th>
        <th>Price</th>
        <th>Offer</th>
        <!-- <th>Purchased</th> -->
        <th>Stock</th>
        <th>Status</th>
        <th>Date</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody id="productTable">
      <% if (typeof products !== 'undefined' && products.length > 0) { %> <%
      products.forEach(product => { %>
      <tr>
        <td class="product-image">
          <img
            src="<%= product.images[0] %>"
            alt="Product Image"
            style="width: 50px; height: 50px; object-fit: cover"
          />
        </td>
        <td class="product-name"><%= product.name %></td>
        <td class="product-price">₹ <%= product.price %></td>
        <td class="product-offer"><%= product.discount || 0 %>%</td>
        <td class="product-stock"><%= product.stock %></td>
        <td
          class="product-status <%= product.status === 'active' ? 'status-active' : (product.status === 'pending' ? 'status-pending' : 'status-disable') %>"
        >
          <%= product.status %>
        </td>
        <td class="product-date">
          <%= new Date(product.createdAt).toLocaleDateString('en-IN') %>
        </td>
        <td class="product-actions">
          <button
            class="action-btn edit-btn"
            data-tooltip="Edit"
            data-id="<%= product._id %>"
            onclick="openEditForm('<%= product._id %>')"
          >
            <i class="uil uil-edit"></i>
          </button>
          <button
            class="action-btn delete-btn"
            data-tooltip="Delete"
            data-id="<%= product._id %>"
            onclick="deleteProduct('<%= product._id %>')"
          >
            <i class="uil uil-trash-alt"></i>
          </button>
        </td>
      </tr>
      <% }); %> <% } else { %>
      <tr>
        <td colspan="9" style="text-align: center; padding: 20px">
          No products found
        </td>
      </tr>
      <% } %>
    </tbody>
  </table>
</div>

<div class="editFormContainer" id="editForm" style="display: none">
  <form
    action="/admin/api/products/update"
    method="POST"
    enctype="multipart/form-data"
    class="editProductForm"
    id="updateProductForm"
  >
    <div class="data-field">
      <label for="image">Product Image:</label>
      <div class="image-upload-container">
        <div class="image-box">
          <input
            type="file"
            id="fileInput1"
            name="image1"
            accept="image/*"
            onchange="previewImage(event, 'preview1')"
          />
          <img id="preview1" src="" alt="Upload" class="preview" />
        </div>
      </div>
    </div>
    <div class="data-field">
      <label for="name">Product Name:</label>
      <input type="text" id="name" name="name" required />
    </div>
    <div class="data-field">
      <label for="description">Description:</label>
      <textarea
        id="description"
        name="description"
        rows="4"
        required
      ></textarea>
    </div>
    <div class="data-field">
      <label for="keywords">Keywords:</label>
      <textarea id="keywords" name="keywords" rows="4" required></textarea>
    </div>
    <div class="data-field">
      <div class="pricing-and-stock">
        <div class="input-field">
          <label for="price">Price:</label>
          <input type="number" id="price" name="price" step="0.01" required />
        </div>
        <div class="input-field">
          <label for="discount">Discount:</label>
          <input type="number" id="discount" name="discount" required />
        </div>
      </div>
    </div>
    <div class="data-field">
      <label for="stock">Stock Quantity:</label>
      <input type="number" id="stock" name="stock" required />
    </div>
    <div class="data-field">
      <div class="select-weight">
        <label for="product-weights">Product Weights (in g):</label>
        <div class="weights-wrapper flex">
          <input type="text" name="weight1" value="" />
          <input type="text" name="weight2" value="" />
          <input type="text" name="weight3" value="" />
          <input type="text" name="weight4" value="" />
        </div>
      </div>
    </div>
    <div class="data-field">
      <label for="weight-unit">Weight Unit</label>
      <div class="custom-select-wrapper">
        <select name="weight-unit" id="weight-unit" required>
          <option value="">Select Weight Unit</option>
          <option value="lit">lit</option>
          <option value="ml">ml</option>
          <option value="gm">gm</option>
          <option value="kg">kg</option>
        </select>
        <span class="custom-arrow"><i class="uil uil-angle-down"></i></span>
      </div>
    </div>
    <div class="data-field">
      <label for="category">Category:</label>
      <div class="custom-select-wrapper">
        <select id="category" name="category_id" required>
          <option value="">Select Category</option>
          <% if (typeof categories !== 'undefined' && categories.length > 0) {
          %> <% categories.forEach(cat => { %>
          <option value="<%= cat._id %>"><%= cat.category_name %></option>
          <% }); %> <% } %>
        </select>
        <span class="custom-arrow"><i class="uil uil-angle-down"></i></span>
      </div>
    </div>

    <input type="hidden" id="product_id" name="product_id" value="" />

    <div class="data-field">
      <label for="deal_start">Deal Start Date & Time:</label>
      <input type="datetime-local" id="deal_start" name="deal_start" />
    </div>
    <div class="data-field">
      <label for="deal_end">Deal End Date & Time:</label>
      <input type="datetime-local" id="deal_end" name="deal_end" />
    </div>
    <div class="data-field">
      <label for="deal-status">Deal status:</label>
      <div class="custom-select-wrapper">
        <select id="deal" name="deal-status">
          <option value="inactive">Inactive</option>
          <option value="active">Active</option>
          <option value="expired">expired</option>
        </select>
        <span class="custom-arrow"><i class="uil uil-angle-down"></i></span>
      </div>
    </div>
    <div class="data-field">
      <label for="status">Status:</label>
      <div class="custom-select-wrapper">
        <select id="status" name="status">
          <option value="active">Active</option>
          <option value="pending">Pending</option>
          <option value="disable">Disable</option>
        </select>
        <span class="custom-arrow"><i class="uil uil-angle-down"></i></span>
      </div>
    </div>

    <button type="submit" class="butn updateProduct">Update Product</button>
    <button type="button" class="butn closeForm" onclick="closeEditForm()">
      Cancel
    </button>
  </form>
</div>
